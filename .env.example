# Server
PORT=3000
NODE_ENV=development

# Shopify Admin (private app or custom app)
# Store: short name (myshop) or full domain (myshop.myshopify.com)
SHOPIFY_STORE=your-store
# Admin API access token from your Shopify custom app (Settings → Apps)
SHOPIFY_ACCESS_TOKEN=your_shopify_admin_api_token
# App automation tokens (CLI deploy only) are NOT the same as Admin API tokens — do not use here.
# SHOPIFY_APP_AUTOMATION_TOKEN=
# Required for webhook HMAC verification (app client secret from Partner/Dev Dashboard)
SHOPIFY_API_SECRET=your_app_client_secret
SHOPIFY_API_VERSION=2025-01

# OAuth (Dev Dashboard / Partner apps — use when Shopify does not show a static Admin token)
SHOPIFY_CLIENT_ID=
# Public HTTPS base of THIS service (ngrok / Cloudflare Tunnel). Redirect URL in app settings must be:
#   {APP_BASE_URL}/api/auth/shopify/callback
APP_BASE_URL=
# Optional: comma-separated scopes (defaults in src/config/index.js cover translations + catalog + theme + menus)
# SHOPIFY_SCOPES=
# Optional: where OAuth callback writes the token JSON (default data/shopify-token.json)
# SHOPIFY_TOKEN_PATH=data/shopify-token.json

# Base language: Dutch (NL)
SOURCE_LOCALE=nl

# Target languages: German, French, English, Italian, Spanish, Polish
TARGET_LOCALES=de,fr,en,it,es,pl

# DeepL — run: npm run test:deepl  (writes data/deepl-api-base.json + validates .env)
DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Pro: https://api.deepl.com | Free: https://api-free.deepl.com
DEEPL_API_BASE=https://api.deepl.com

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Workers / webhooks
DISABLE_WEBHOOKS=false
DISABLE_WORKERS=false
TRANSLATION_QUEUE_CONCURRENCY=3
# Parallel products for npm run translate:text-only (default 6; try 8–10 on stable network)
PRODUCT_TRANSLATE_CONCURRENCY=6
SHOPIFY_REQUESTS_PER_SECOND=4
DEEPL_REQUESTS_PER_SECOND=10
JOB_ATTEMPTS=5
JOB_BACKOFF_MS=5000

# Optional: path to glossary JSON (default config/glossary.json)
# GLOSSARY_PATH=config/glossary.json

# Theme bulk: source locale file in MAIN theme
# THEME_SOURCE_ASSET=locales/nl.json
