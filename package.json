{
  "name": "shopify-markets-localization",
  "version": "1.0.0",
  "description": "Production-ready Shopify Markets localization via DeepL and native Translations API",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "worker": "node src/workers/translation.worker.js",
    "redis:up": "docker compose up -d redis",
    "redis:ping": "node scripts/redis-ping.js",
    "test:shopify": "node scripts/test-shopify-api.js",
    "test:deepl": "node scripts/test-deepl-api.js",
    "check:locales": "node scripts/check-shop-locales.js",
    "bulk:products": "node scripts/bulk-products.js",
    "bulk:collections": "node scripts/bulk-collections.js",
    "bulk:pages": "node scripts/bulk-pages.js",
    "bulk:blogs": "node scripts/bulk-blogs.js",
    "bulk:menus": "node scripts/bulk-menus.js",
    "bulk:theme-locale": "node scripts/bulk-theme-locale.js",
    "bulk:theme-translations": "node scripts/bulk-theme-translations.js",
    "patch:theme-snippets": "node scripts/patch-theme-snippets.js",
    "fix:storefront-strings": "node scripts/fix-storefront-strings.js",
    "fix:storefront-v3": "node scripts/fix-storefront-v3.js",
    "fix:dutch-titles": "node scripts/fix-dutch-titles-quick.js",
    "translate:catalog-bodies": "node scripts/translate-catalog-bodies.js",
    "fix:terminology": "node scripts/fix-terminology-cleanup.js",
    "fix:production": "node scripts/fix-production-issues.js",
    "fix:flagship-live": "node scripts/fix-flagship-live.js",
    "fix:qa-p1-p2": "node scripts/fix-qa-p1-p2.js",
    "fix:flagship-qa": "node scripts/fix-flagship-qa.js",
    "fix:product-page-theme": "node scripts/fix-product-page-theme.js",
    "apply:product-qa": "node scripts/apply-product-locale-qa.js",
    "terms:list": "node scripts/list-motorsport-terms.js",
    "terms:generate": "node scripts/generate-motorsport-terminology.js",
    "list:theme-locales": "node scripts/list-theme-locale-assets.js",
    "translate:store": "node scripts/translate-store-complete.js",
    "translate:store:no-redis": "node scripts/translate-store-complete.js --no-redis",
    "translate:store:full": "node scripts/translate-store-full.js",
    "translate:text-only": "node scripts/translate-text-only.js",
    "translate:theme-text-only": "node scripts/translate-theme-text-only.js",
    "fix:product-options": "node scripts/fix-product-options-all.js",
    "translate:theme-ui": "node scripts/translate-theme-ui-all.js",
    "verify:locale": "node scripts/verify-store-locale.js",
    "translate:product": "node scripts/translate-product-complete.js",
    "translate:product:full": "node scripts/translate-product-complete.js",
    "audit:product-page": "node scripts/audit-product-page-locale.js",
    "audit:product-page:all": "node scripts/audit-product-page-all.js",
    "audit:product-page:summary": "node scripts/audit-product-page-summary.js",
    "audit:store": "node scripts/audit-store-catalog.js",
    "audit:structural": "node scripts/audit-structural-issues.js",
    "complete:product-page": "node scripts/complete-product-page-locales.js",
    "fix:pipeline-v2": "node scripts/fix-pipeline-v2.js",
    "diagnose:v2": "node scripts/diagnose-storefront-v2.js",
    "qa:product": "node scripts/apply-product-locale-qa.js",
    "fix:jt-locale-keys": "node scripts/fix-jt-theme-locale-keys.js",
    "fix:jt-fallback": "node -e \"require('dotenv').config(); require('./src/config').assertRequired(); require('./src/services/jtLocaleFallback.service').deployJtLocaleFallback().then(r=>console.log(r)).catch(e=>{console.error(e.message);process.exit(1)})\""
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bullmq": "^5.34.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "winston": "^3.17.0"
  }
}
